# OpenSight — copy to .env and edit.
# All values are optional; defaults work for local development.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./opensight.db
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/opensight

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=500

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins. No wildcards.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── NLP ───────────────────────────────────────────────────────────────────────
# spaCy model name. spaCy is used automatically when the model is available.
# Install model: python -m spacy download en_core_web_sm
SPACY_MODEL=en_core_web_sm

# ── OCR ───────────────────────────────────────────────────────────────────────
# Enable OCR for scanned PDFs and image files.
# Requires: pip install pymupdf pytesseract Pillow && apt install tesseract-ocr
USE_OCR=false
OCR_LANGUAGE=eng

# ── Redaction detection ───────────────────────────────────────────────────────
# Detect black-box redactions and hidden text in PDFs.
# Requires: pip install pymupdf
USE_REDACTION_DETECTION=true

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
